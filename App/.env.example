# ─────────────────────────────────────────────────────────────
# DB_PROVIDER — elige el proveedor de base de datos
# Valores permitidos: postgres | supabase | memory
# ─────────────────────────────────────────────────────────────
DB_PROVIDER=supabase

# ── Opción 1: postgres (Docker local, sin SSL) ──────────────
DB_USER=banco_user
DB_PASSWORD=banco_password
DB_HOST=db
DB_PORT=5432
DB_NAME=banco_db
DB_SSLMODE=disable

# ── Opción 2: supabase (PostgreSQL remoto, SSL automático) ──
# DB_PROVIDER=supabase
# DB_USER=postgres.xxxxxxxxxxxx
# DB_PASSWORD=tu_password_supabase
# DB_HOST=aws-0-us-east-1.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# (o simplemente pon la URL completa de Supabase:)
# DATABASE_URL=postgresql+psycopg2://postgres.xxx:password@host:6543/postgres?sslmode=require

# ── Opción 3: memory (SQLite en RAM, sin instalación) ────────
# DB_PROVIDER=memory
# (no requiere ninguna otra variable de BD)

# ─────────────────────────────────────────────────────────────
# AWS Lambda Login Notifier
# ─────────────────────────────────────────────────────────────
LOGIN_EVENTS_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/
LOGIN_EVENTS_SECRET=your_shared_secret_here
LOGIN_EVENTS_TIMEOUT=2.5
SERVICE_NAME=bankservice
ENVIRONMENT=dev
